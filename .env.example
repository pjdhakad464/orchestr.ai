# ─── OrchestrAI Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
WORKERS=2

# ── Application ──────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=12
CACHE_TTL_SECONDS=900

# ── API Keys (required for full functionality) ───────────────────────────
SERPAPI_API_KEY=
SERPAPI_ENGINE=google
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=
OMDB_API_KEY=
YOUTUBE_API_KEY=

# ── Wikimedia ────────────────────────────────────────────────────────────
WIKIMEDIA_CONTACT=your-email@example.com
WIKIPEDIA_CACHE_DIR=./data/wikipedia_cache
WIKIPEDIA_REFRESH_HOURS=24

# ── IMDb Datasets ────────────────────────────────────────────────────────
IMDB_TITLE_BASICS_URL=https://datasets.imdbws.com/title.basics.tsv.gz
IMDB_NAME_BASICS_URL=https://datasets.imdbws.com/name.basics.tsv.gz
IMDB_DATASET_DIR=./data/imdb_datasets
IMDB_DATASET_REFRESH_HOURS=168

# ── Google Sheets Export (optional) ──────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=

# ── Database / Persistent Storage ────────────────────────────────────────
DATA_DIR=./data
VALIDATED_RUNS_DIR=./validated_runs

# ── Hugging Face Spaces Synchronization (optional) ──────────────────────
# Required only for database persistence on Hugging Face Spaces free tier.
# Set these as secrets in the Hugging Face Space settings.
HF_DATASET_ID=
HF_TOKEN=
# ─── Git Remote Reference ──────────────────────────────────────────────────
# Linked Repository: pjdhakad464/orchestr.ai
