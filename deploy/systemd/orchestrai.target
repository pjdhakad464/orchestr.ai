[Unit]
Description=OrchestrAI Service Suite
Requires=orchestrai-validator.service \
         orchestrai-title-lookup.service \
         orchestrai-calendar.service \
         orchestrai-imdb.service
After=orchestrai-validator.service \
      orchestrai-title-lookup.service \
      orchestrai-calendar.service \
      orchestrai-imdb.service

[Install]
WantedBy=multi-user.target

